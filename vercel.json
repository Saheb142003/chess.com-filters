{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/chess/:username",
      "destination": "/backend/server.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "backend/server.js": {
      "runtime": "vercel-node@latest",
      "memory": 1024,
      "maxDuration": 15
    }
  }
}
